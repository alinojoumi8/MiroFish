.ruff_cache

# Build artifacts
frontend/dist
frontend/.vite

# Local data / state (mounted as volumes at runtime, no need to ship in image)
backend/uploads
backend/app/uploads/.llm_provider_state.json

# Editor / IDE
.idea
.vscode

# Misc
*.log
.claude
