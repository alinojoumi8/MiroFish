# ============================================================
# LLM API 配置（支持 OpenAI SDK 格式的任意 LLM）
# ============================================================
# 可在多个 provider 之间通过 UI / API 运行时切换。
# 启动默认 provider（仅状态文件不存在时使用）：
LLM_PROVIDER=minimax

# ---- MiniMax M2 ----
# https://platform.minimaxi.com
MINIMAX_API_KEY=your_minimax_api_key_here

# ---- Kimi K2 Thinking (Moonshot AI) ----
# https://platform.moonshot.ai
KIMI_API_KEY=your_kimi_api_key_here

# ---- Custom provider（任意 OpenAI 兼容端点）----
# 仅在通过 UI 选择 "custom" provider 时生效；不需要可留空 / 删除整段
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== 加速 LLM 配置（可选，并行模拟用）=====
# 如果不使用加速配置，env 文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here


# ============================================================
# 记忆后端配置
# ============================================================
# graphiti = 本地 Neo4j（推荐，零外部依赖）
# zep      = Zep Cloud（保留作兜底）
MEMORY_BACKEND=graphiti

# ---- Graphiti / 本地 Neo4j ----
# 通过 `docker compose up -d neo4j` 启动本地实例
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish-neo4j

# 本地嵌入 / 重排序模型（首次运行会自动下载到 HuggingFace 缓存）
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# ---- Zep Cloud（仅 MEMORY_BACKEND=zep 时需要）----
# https://app.getzep.com/
ZEP_API_KEY=


# ============================================================
# URL 抓取（Step 1: 粘贴 URL 输入）
# ============================================================
# 通过 Jina Reader (r.jina.ai) 把任意网页转为 LLM-ready 的 Markdown。
# 不设置 token 也能用，免费配额足够日常使用；如需更高速率/优先级，
# 在 https://jina.ai/reader 申请 token 后填入下方。
# 文档: https://jina.ai/reader/
JINA_API_KEY=
